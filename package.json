{
  "name": "movyo-desktop",
  "version": "2.2.1",
  "description": "Movyo Food — Sistema desktop para gestão de pedidos, entregas e operações do restaurante.",
  "author": "Movyo Tecnologia",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 vite build",
    "dist": "npm run build && cross-env NODE_OPTIONS=--max-old-space-size=8192 electron-builder --win nsis",
    "dist:publish": "npm run build && cross-env NODE_OPTIONS=--max-old-space-size=8192 electron-builder --win nsis --publish always",
    "rebuild": "electron-rebuild",
    "start": "electron .",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.movyo.desktop",
    "productName": "Movyo Food",
    "files": [
      "renderer/**/*",
      "main.js",
      "preload.js",
      "assets/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "src/printerInstall",
        "to": "printerInstall"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "linux": {
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Movyo Food",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "include": "installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "MovyoTech",
        "repo": "Movyo-Desktop",
        "private": true
      }
    ]
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mapbox/mapbox-gl-draw": "^1.5.0",
    "@mui/icons-material": "^7.0.2",
    "@mui/material": "^7.0.2",
    "axios": "^1.9.0",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.13",
    "dotenv": "^17.2.0",
    "electron-log": "^5.4.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.18.1",
    "howler": "^2.2.4",
    "iconv-lite": "^0.6.3",
    "lucide-react": "^0.503.0",
    "mapbox-gl": "^3.12.0",
    "moment": "^2.30.1",
    "node-thermal-printer": "^4.5.0",
    "printer-node": "^1.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-csv": "^2.2.2",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.0.0",
    "react-input-mask": "^2.0.4",
    "react-qr-code": "^2.0.15",
    "react-router-dom": "^7.5.1",
    "recharts": "^2.15.3",
    "socket.io-client": "^4.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "vite": "^6.3.1"
  }
}
